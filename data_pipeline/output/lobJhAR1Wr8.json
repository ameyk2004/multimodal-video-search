[
  {
    "text": "[संगीत]",
    "start_time": 0.37,
    "duration": 17.1
  },
  {
    "text": "तीन च्या सुमाराडे",
    "start_time": 20.16,
    "duration": 3.4
  },
  {
    "text": "[संगीत]",
    "start_time": 26.14,
    "duration": 6.539
  },
  {
    "text": "त्यावेळेस माहित नाही",
    "start_time": 28.4,
    "duration": 4.279
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 35.36,
    "duration": 7.06
  },
  {
    "text": "तेवढ जाऊन पुण्य",
    "start_time": 38.399,
    "duration": 5.281
  },
  {
    "text": "[संगीत]",
    "start_time": 42.42,
    "duration": 3.42
  },
  {
    "text": "आधी",
    "start_time": 43.68,
    "duration": 4.24
  },
  {
    "text": "त्यावेळची",
    "start_time": 45.84,
    "duration": 6.76
  },
  {
    "text": "घटना घडली आपल्या",
    "start_time": 47.92,
    "duration": 4.68
  },
  {
    "text": "संबंधित वाच",
    "start_time": 54.0,
    "duration": 3.48
  },
  {
    "text": "सद्गुरुनाथ महाराज की जय",
    "start_time": 60.16,
    "duration": 5.48
  },
  {
    "text": ">> 1918",
    "start_time": 67.6,
    "duration": 5.6
  },
  {
    "text": "दसऱ्याच्या महोत्सवाच्या दहाबारा दिवस आधी",
    "start_time": 70.08,
    "duration": 5.68
  },
  {
    "text": "एक अपशगून घडला.",
    "start_time": 73.2,
    "duration": 6.08
  },
  {
    "text": "बाबांची हलोक सोडून परलोकी प्रयाण",
    "start_time": 75.76,
    "duration": 5.76
  },
  {
    "text": "करण्याची वेळ आली असल्याचे चिंता नजरेला",
    "start_time": 79.28,
    "duration": 6.44
  },
  {
    "text": "आले. झोपताना",
    "start_time": 81.52,
    "duration": 4.2
  },
  {
    "text": "[संगीत]",
    "start_time": 86.34,
    "duration": 3.109
  },
  {
    "text": "झोपताना बाबा एक जुनी वीट उषाला घेत असत.",
    "start_time": 89.52,
    "duration": 9.12
  },
  {
    "text": "ही वीट त्यांना त्यांचे गुरु वेंकुसा",
    "start_time": 94.0,
    "duration": 6.64
  },
  {
    "text": "यांनी एका जुन्या पुराण्या फडक्यात",
    "start_time": 98.64,
    "duration": 4.4
  },
  {
    "text": "गुंडाळून दिली होती",
    "start_time": 100.64,
    "duration": 7.2
  },
  {
    "text": "माधव फसले हा बाबांचा सेवक रोज तीवी त्या",
    "start_time": 103.04,
    "duration": 7.84
  },
  {
    "text": "फाटक्या कपड्यात गुंडाळून माळसापतीकडे देत",
    "start_time": 107.84,
    "duration": 8.08
  },
  {
    "text": "असे त्या दिवशी माधवाने बाबांचे अंथरून",
    "start_time": 110.88,
    "duration": 8.4
  },
  {
    "text": "आणखी मऊ करण्यासाठी त्यावर आणखी काही जुनी",
    "start_time": 115.92,
    "duration": 6.799
  },
  {
    "text": "पुराणी फडकी पसरली",
    "start_time": 119.28,
    "duration": 4.56
  },
  {
    "text": "माधव",
    "start_time": 122.719,
    "duration": 4.08
  },
  {
    "text": "ती वीट हातात घेऊन माळसापतीच्या हातात देत",
    "start_time": 123.84,
    "duration": 5.44
  },
  {
    "text": "असताना ती त्याच्या हातून खाली पडून",
    "start_time": 126.799,
    "duration": 7.44
  },
  {
    "text": "त्याचे दोन तुकडे झाले ही वीट कोणी फोडली",
    "start_time": 129.28,
    "duration": 7.76
  },
  {
    "text": "बाबांनी विचारलं",
    "start_time": 134.239,
    "duration": 5.841
  },
  {
    "text": "माधव फसल्यान ती फोडली हे कळताच ते फार",
    "start_time": 137.04,
    "duration": 6.88
  },
  {
    "text": "रागवले त्यांनी आपल्या डोक्यावर हात ठेवले",
    "start_time": 140.08,
    "duration": 10.159
  },
  {
    "text": "व व्यथित अंतकरणाने म्हणाले सोबत तुटली",
    "start_time": 143.92,
    "duration": 9.52
  },
  {
    "text": "दुसऱ्या दिवशी त्यांचे एक शिष्य एच एस",
    "start_time": 150.239,
    "duration": 6.801
  },
  {
    "text": "दीक्षित म्हणाले बंगली म्हणून एवढं दुःख",
    "start_time": 153.44,
    "duration": 6.159
  },
  {
    "text": "करायचं काही कारण नाही मी ती चांदीने",
    "start_time": 157.04,
    "duration": 4.8
  },
  {
    "text": "जोडून देईल",
    "start_time": 159.599,
    "duration": 4.72
  },
  {
    "text": "त्यावर बाबा म्हणाले तुम्ही ती सोन्याने",
    "start_time": 161.84,
    "duration": 6.32
  },
  {
    "text": "जरी जोडली असली तरी त्याचा आता काय उपयोग",
    "start_time": 164.319,
    "duration": 7.28
  },
  {
    "text": "ती वीट हा माझा सोत्या आहे आणि तो तुटला",
    "start_time": 168.16,
    "duration": 7.92
  },
  {
    "text": "हे दुश्चन आहे ते पुढे म्हणाले ही वीट",
    "start_time": 171.599,
    "duration": 7.681
  },
  {
    "text": "माझ्या गुरुन मला दिलेली देणगी आहे तो",
    "start_time": 176.08,
    "duration": 7.36
  },
  {
    "text": "माझा जीवन सारथी आहे आणि आता आता मी काही",
    "start_time": 179.28,
    "duration": 8.319
  },
  {
    "text": "यातून वाचत नाही नाना चांदोरकरांनी सुद्धा",
    "start_time": 183.44,
    "duration": 7.2
  },
  {
    "text": "ती भंगलेली",
    "start_time": 187.599,
    "duration": 6.56
  },
  {
    "text": "साधून देण्याची तयारी नसली",
    "start_time": 190.64,
    "duration": 6.64
  },
  {
    "text": "पण बाबा त्यांना म्हणाले",
    "start_time": 194.159,
    "duration": 5.841
  },
  {
    "text": "तुम्ही लाख उषा आणल्यात तर या विटेची",
    "start_time": 197.28,
    "duration": 6.0
  },
  {
    "text": "किंमत चुकती करता येणार नाही ही वीट मला",
    "start_time": 200.0,
    "duration": 6.56
  },
  {
    "text": "माझ्या गुरूंनी दिली होती त्याची किंमत",
    "start_time": 203.28,
    "duration": 6.72
  },
  {
    "text": "संपूर्ण विश्वापेक्षा सुद्धा अधिक आहे ही",
    "start_time": 206.56,
    "duration": 7.28
  },
  {
    "text": "वीट माझ्या ध्यानाच धय आहे आणि माझं",
    "start_time": 210.0,
    "duration": 8.239
  },
  {
    "text": "ध्यानही तेच आहे वीट म्हणजे माझं दृश्य",
    "start_time": 213.84,
    "duration": 8.399
  },
  {
    "text": "आयुष्य आहे जर ही केली तर त्याचा अर्थ",
    "start_time": 218.239,
    "duration": 6.881
  },
  {
    "text": "माझा हा देह सुद्धा जाणार",
    "start_time": 222.239,
    "duration": 5.841
  },
  {
    "text": "परभणी जिल्ह्यातील सेलू जवळच्या जंगलात",
    "start_time": 225.12,
    "duration": 6.56
  },
  {
    "text": "जेव्हा माझ्या गुरु बरोबर होतो तेव्हा",
    "start_time": 228.08,
    "duration": 6.879
  },
  {
    "text": "आम्हा दोघांना ठार मारण्याच्या उद्देशाने",
    "start_time": 231.68,
    "duration": 6.639
  },
  {
    "text": "एका दुष्टाने नेम धरून आम्हाला दगड विटा",
    "start_time": 234.959,
    "duration": 6.081
  },
  {
    "text": "मारायला सुरुवात केली.",
    "start_time": 238.319,
    "duration": 5.92
  },
  {
    "text": "जी वीट माझ्यावर नेम धरून मारली होती ती",
    "start_time": 241.04,
    "duration": 6.559
  },
  {
    "text": "माझ्या गुरूंच्या डोक्यावर आदळली. आणि तीच",
    "start_time": 244.239,
    "duration": 6.64
  },
  {
    "text": "ही वीट आहे. माझ्या गुरूंच सामर्थ्य",
    "start_time": 247.599,
    "duration": 6.961
  },
  {
    "text": "जगावेगळ होतं. त्यांनी ही वीट दीड तास",
    "start_time": 250.879,
    "duration": 7.441
  },
  {
    "text": "हवेत तरंगत ठेवली. ती तशीच आणखी राहिली",
    "start_time": 254.56,
    "duration": 7.12
  },
  {
    "text": "असती. पण त्याचा वेग थांबवण्यासाठी ती",
    "start_time": 258.32,
    "duration": 6.48
  },
  {
    "text": "कशावर तरी आदळण आवश्यक होत. माझ्या",
    "start_time": 261.68,
    "duration": 6.0
  },
  {
    "text": "सद्गुरूंनी स्वतःच डोक त्यासाठी पुढे करून",
    "start_time": 264.8,
    "duration": 6.32
  },
  {
    "text": "मला वाचवलं. मी वाचलो पण त्यांना त्याचा",
    "start_time": 267.68,
    "duration": 7.44
  },
  {
    "text": "त्रास झाला यातून एक गोष्ट लक्षात येते",
    "start_time": 271.12,
    "duration": 6.799
  },
  {
    "text": "संत महात्मे इतरांचा त्रास स्वतःवर ओडून",
    "start_time": 275.12,
    "duration": 6.0
  },
  {
    "text": "घेत असतात त्यांच्यापाशी प्रचंड आंतरिक",
    "start_time": 277.919,
    "duration": 6.801
  },
  {
    "text": "शक्ती असते पण ते त्या त्याच प्रदर्शन",
    "start_time": 281.12,
    "duration": 7.04
  },
  {
    "text": "मात्र कधी करत नाही मी ती उचलून माझ्या",
    "start_time": 284.72,
    "duration": 5.6
  },
  {
    "text": "गुरूंच्या चरणापाशी ठेवली व माझ्या",
    "start_time": 288.16,
    "duration": 5.52
  },
  {
    "text": "सद्गुरूंनी ती मला देगी म्हणून दिली",
    "start_time": 290.32,
    "duration": 6.0
  },
  {
    "text": "माझ्या गुरूंचा चरण स्पर्श तिला झाला आहे",
    "start_time": 293.68,
    "duration": 5.84
  },
  {
    "text": "म्हणून मी माझे मस्तक तिच्यावर ठेवतो व",
    "start_time": 296.32,
    "duration": 7.12
  },
  {
    "text": "त्या विटेची उशी करून झोपतो माझे गुरु",
    "start_time": 299.52,
    "duration": 6.8
  },
  {
    "text": "गोपाळराव यांनी त्यात प्रवेश करून ते",
    "start_time": 303.44,
    "duration": 6.24
  },
  {
    "text": "व्ेंकटेश बनले त्या व्ेंकटेशाच्या पाऊलखणा",
    "start_time": 306.32,
    "duration": 6.719
  },
  {
    "text": "या विटेवरच आहेत म्हणून मी माझ्या गुरूंना",
    "start_time": 309.68,
    "duration": 6.16
  },
  {
    "text": "व्ेंकुसा म्हणून हाक मारतो या विटेचा",
    "start_time": 313.039,
    "duration": 5.921
  },
  {
    "text": "महिमा हा असा अगाल आहे",
    "start_time": 315.84,
    "duration": 5.68
  },
  {
    "text": "भक्त म्हणतात",
    "start_time": 318.96,
    "duration": 6.0
  },
  {
    "text": "त्या दिवसापासून बाबा उदास झाले त्यांचा",
    "start_time": 321.52,
    "duration": 6.0
  },
  {
    "text": "आयुष्याबद्दलचा उत्साह मावळला आता काही",
    "start_time": 324.96,
    "duration": 5.2
  },
  {
    "text": "दिवसात मी या मशिदीपासून दूर जाणार अस ते",
    "start_time": 327.52,
    "duration": 5.92
  },
  {
    "text": "म्हणू लागले पण तत्पूर्वी काही दिवस",
    "start_time": 330.16,
    "duration": 6.56
  },
  {
    "text": "त्यांनी माणसापतीला एक ओझरता इशारा दिला",
    "start_time": 333.44,
    "duration": 6.88
  },
  {
    "text": "होता एकदा माळसापती त्यांची चिली पेटवत",
    "start_time": 336.72,
    "duration": 6.56
  },
  {
    "text": "होता त्यावेळी बाबा त्याला म्हणाले अरे",
    "start_time": 340.32,
    "duration": 7.04
  },
  {
    "text": "भगत अजून काही दिवसांनी मी कुठेतरी जाणार",
    "start_time": 343.28,
    "duration": 7.199
  },
  {
    "text": "आहे त्यानंतर तू दोन चार वर्षे फक्त",
    "start_time": 347.36,
    "duration": 6.64
  },
  {
    "text": "रात्री येत जा बाबांना नक्की काय म्हणायचं",
    "start_time": 350.479,
    "duration": 8.0
  },
  {
    "text": "होतं ते माणसाला नीट समजे 15 ऑक्टोबर 198",
    "start_time": 354.0,
    "duration": 8.0
  },
  {
    "text": "रोजी बाबांचा मृत्यू झाला व त्यानंतर",
    "start_time": 358.479,
    "duration": 5.681
  },
  {
    "text": "बाबांची रात्रीची पूजा करण सुद्धा",
    "start_time": 362.0,
    "duration": 5.28
  },
  {
    "text": "माळसापतीच्या हातून फार थोडा काळ घडलं",
    "start_time": 364.16,
    "duration": 7.599
  },
  {
    "text": "कारण सप्टेंबर 11 1922 रोजी माळसापतीचाही",
    "start_time": 367.28,
    "duration": 6.8
  },
  {
    "text": "मृत्यू झाला",
    "start_time": 371.759,
    "duration": 7.041
  },
  {
    "text": "15 ऑक्टोबर 1918 हा विजयादशमीचा दिवस",
    "start_time": 374.08,
    "duration": 7.2
  },
  {
    "text": "बाबांना आपला मृत्यू होणार याची अगदी",
    "start_time": 378.8,
    "duration": 5.6
  },
  {
    "text": "पूर्ण कल्पना होती त्यांनी मशिदीत एका",
    "start_time": 381.28,
    "duration": 5.759
  },
  {
    "text": "भक्ताला धर्मग्रंथाचा प्रषण करायला लावला",
    "start_time": 384.4,
    "duration": 5.68
  },
  {
    "text": "त्याचप्रमाणे मुसलमान साधू शमसुद्दीन",
    "start_time": 387.039,
    "duration": 5.521
  },
  {
    "text": "यांच्याकडे त्याच्या धर्माची प्रार्थना",
    "start_time": 390.08,
    "duration": 6.0
  },
  {
    "text": "करण्यासाठी अडीश रुपये पाठवले बाबा मिया",
    "start_time": 392.56,
    "duration": 6.24
  },
  {
    "text": "नामक आणखी एका संताला त्यांनी निरोप",
    "start_time": 396.08,
    "duration": 4.239
  },
  {
    "text": "पाठवला",
    "start_time": 398.8,
    "duration": 4.32
  },
  {
    "text": "आम्ही नवव्या महिन्याच्या नवव्या दिवशी",
    "start_time": 400.319,
    "duration": 6.0
  },
  {
    "text": "परलोकी प्रयाण करणार आहोत",
    "start_time": 403.12,
    "duration": 7.12
  },
  {
    "text": "हा संदर्भ बहुदा मुस्लिम कॅलेंडरचा असावा",
    "start_time": 406.319,
    "duration": 8.641
  },
  {
    "text": "ते असही म्हणाले अल्लाने जो दिवा अल्लाने",
    "start_time": 410.24,
    "duration": 6.72
  },
  {
    "text": "जो दिवा पेटवला",
    "start_time": 414.96,
    "duration": 5.84
  },
  {
    "text": "तोच आता तो परत घेऊन चाललाय",
    "start_time": 416.96,
    "duration": 7.12
  },
  {
    "text": "सकाळी त्यांनी दानधर्म केला नंतर खिशात",
    "start_time": 420.8,
    "duration": 7.36
  },
  {
    "text": "हात घालून पाच रुपये बाहेर काढले परत एकदा",
    "start_time": 424.08,
    "duration": 6.399
  },
  {
    "text": "हात घालून आणखी चार रुपये काढले व ते",
    "start_time": 428.16,
    "duration": 5.68
  },
  {
    "text": "लक्ष्मीबाई शिंदे तिच्या हातावर ठेवले हीच",
    "start_time": 430.479,
    "duration": 5.921
  },
  {
    "text": "रोज सकाळी स्वयपाक करून बाबांना जेवायला",
    "start_time": 433.84,
    "duration": 6.4
  },
  {
    "text": "आवडत असे व त्याबद्दल तिला बाबांकडून चार",
    "start_time": 436.4,
    "duration": 6.639
  },
  {
    "text": "रुपये रोज पगार मिळत असे काही",
    "start_time": 440.24,
    "duration": 4.88
  },
  {
    "text": "दिवसांपूर्वी बाबांनी धार्मिक स्थळी",
    "start_time": 443.039,
    "duration": 5.201
  },
  {
    "text": "फकीरांना जेव घालण्यासाठी तसेच ढोल ताशे",
    "start_time": 445.12,
    "duration": 5.919
  },
  {
    "text": "वाजवून मंत्र पठन करण्यासाठी दोश रुपये",
    "start_time": 448.24,
    "duration": 6.0
  },
  {
    "text": "पाठवले होते.",
    "start_time": 451.039,
    "duration": 7.6
  },
  {
    "text": "बाबा आजारी असताना त्यांनी आपल्या वागणे",
    "start_time": 454.24,
    "duration": 7.6
  },
  {
    "text": "नामक भक्ताला बोलावले व हिंदी भाषेतील",
    "start_time": 458.639,
    "duration": 5.84
  },
  {
    "text": "रामायणाचा पाठ करायला लावला. आधी",
    "start_time": 461.84,
    "duration": 6.0
  },
  {
    "text": "आठवड्यातून एकदा व नंतर अखंड रात्रंदिवस",
    "start_time": 464.479,
    "duration": 6.401
  },
  {
    "text": "पुन्हा एकदा वाचायला लावून तीनच दिवसात",
    "start_time": 467.84,
    "duration": 6.24
  },
  {
    "text": "संपूर्ण पाठ संपवायला लावा. असं करता करता",
    "start_time": 470.88,
    "duration": 5.599
  },
  {
    "text": "तीन वेळा रामायणाचा पाठ करून झाल्यावर तो",
    "start_time": 474.08,
    "duration": 4.399
  },
  {
    "text": "भक्त थकला",
    "start_time": 476.479,
    "duration": 5.12
  },
  {
    "text": "मग बाबांनी त्याला सोडलं आणि उरलेला दिवस",
    "start_time": 478.479,
    "duration": 6.241
  },
  {
    "text": "पाळला नंतर बाबा नेहमीप्रमाणे भिक्षा",
    "start_time": 481.599,
    "duration": 6.801
  },
  {
    "text": "मागायला गेले मात्र काही भक्तांनी त्यांना",
    "start_time": 484.72,
    "duration": 8.96
  },
  {
    "text": "आधार देऊन चालवत नाही काही दिवसातच तेही",
    "start_time": 488.4,
    "duration": 7.76
  },
  {
    "text": "अशक्य होऊन",
    "start_time": 493.68,
    "duration": 4.88
  },
  {
    "text": "तेही अशक्य होऊन बसल्यावर हा प्रघात",
    "start_time": 496.16,
    "duration": 6.0
  },
  {
    "text": "थांबवायला लागला बाबांची एक स्त्री भक्त",
    "start_time": 498.56,
    "duration": 7.84
  },
  {
    "text": "होती सौ एम डब्ल प्रधान",
    "start_time": 502.16,
    "duration": 7.12
  },
  {
    "text": "हिला बाबांच्या महानिमाणापूर्वी काही दिवस",
    "start_time": 506.4,
    "duration": 6.16
  },
  {
    "text": "एक स्वप्न पडलं स्वप्नात बाबा लोक सोडून",
    "start_time": 509.28,
    "duration": 6.8
  },
  {
    "text": "जाताना तिला दिसले व ती बाबा वारले अस",
    "start_time": 512.56,
    "duration": 5.919
  },
  {
    "text": "म्हणून रडू लागली तोच बाबा तिच्या",
    "start_time": 516.08,
    "duration": 5.92
  },
  {
    "text": "स्वप्नात येऊन म्हणाले संत कधी मरत नाही",
    "start_time": 518.479,
    "duration": 6.241
  },
  {
    "text": "त्यांच्या बाबतीत समाधी घेणे असा वाक",
    "start_time": 522.0,
    "duration": 6.24
  },
  {
    "text": "प्रयोग करायचा असतो",
    "start_time": 524.72,
    "duration": 5.92
  },
  {
    "text": "बाबांची आणखी एक स्त्री भक्त होती बाबा",
    "start_time": 528.24,
    "duration": 5.12
  },
  {
    "text": "मरणार या कल्पनेने ती भयभीत झाली होती ते",
    "start_time": 530.64,
    "duration": 6.72
  },
  {
    "text": "पाहून बाबा तिला म्हणाले आई मी कधीच मरणार",
    "start_time": 533.36,
    "duration": 6.479
  },
  {
    "text": "नाही जेव्हा जेव्हा तुम्ही माझ्याविषयी",
    "start_time": 537.36,
    "duration": 5.52
  },
  {
    "text": "विचार कराल तेव्हा तुम्हाला पाहिजे त्या",
    "start_time": 539.839,
    "duration": 8.68
  },
  {
    "text": "क्षणी मी तिथे असेल सशरीर अथवा अशरीर",
    "start_time": 542.88,
    "duration": 5.639
  },
  {
    "text": "विजयादशमीला चार दिवस उले होते बाबा",
    "start_time": 548.8,
    "duration": 8.0
  },
  {
    "text": "विजयादशमीचा उल्लेख सिमोल्लंघन असा करीत",
    "start_time": 552.08,
    "duration": 7.439
  },
  {
    "text": "सौ आंधू मारवाडी नावाच्या स्थानिक भक्ता",
    "start_time": 556.8,
    "duration": 4.64
  },
  {
    "text": "स्त्रीला बाबा म्हणाले",
    "start_time": 559.519,
    "duration": 5.521
  },
  {
    "text": "बाई आता मला द्वारकामाई व चावडीत",
    "start_time": 561.44,
    "duration": 7.44
  },
  {
    "text": "राहण्याचा कंटाळा आला आहे मी आता बुटीच्या",
    "start_time": 565.04,
    "duration": 7.12
  },
  {
    "text": "वाड्याकडे जाणार आहे तिथे थोर मोठे लोक",
    "start_time": 568.88,
    "duration": 6.32
  },
  {
    "text": "माझ्याकडे लक्ष पुरवतील त्यावेळी बाबांची",
    "start_time": 572.16,
    "duration": 6.4
  },
  {
    "text": "प्रकृती खूपच खालवली होती",
    "start_time": 575.2,
    "duration": 6.4
  },
  {
    "text": "त्यांचा लेंडी बागेतील सकाळचा फेरफटका आता",
    "start_time": 578.56,
    "duration": 6.399
  },
  {
    "text": "बंद पडला होता ते आता भिक्षा मागायलाही",
    "start_time": 581.6,
    "duration": 5.919
  },
  {
    "text": "जात नव्हते फक्त मशिदीत स्वतःला कोंडून",
    "start_time": 584.959,
    "duration": 6.0
  },
  {
    "text": "बसत असत बाबांचे सर्वात निकटवर्ती भक्त",
    "start_time": 587.519,
    "duration": 7.44
  },
  {
    "text": "दीक्षित वटी तेवढे त्यांच्या जवळ असे",
    "start_time": 590.959,
    "duration": 8.721
  },
  {
    "text": "विजयादशमीच्या दिवशीच एकादशी होती",
    "start_time": 594.959,
    "duration": 7.841
  },
  {
    "text": "तेव्हा तात्या पाटील हे बाबांचे जवळचे",
    "start_time": 599.68,
    "duration": 5.599
  },
  {
    "text": "भक्त आजारी झाले",
    "start_time": 602.8,
    "duration": 5.2
  },
  {
    "text": "त्यांची नाडी बंद होऊ लागली स्वतः बाबा",
    "start_time": 605.279,
    "duration": 5.201
  },
  {
    "text": "सुद्धा त्यावेळी फारच आजारी होते तरीही",
    "start_time": 608.0,
    "duration": 5.44
  },
  {
    "text": "अंथरणावर उठून बसून त्यांचा दानधर्म चालूच",
    "start_time": 610.48,
    "duration": 4.64
  },
  {
    "text": "होता",
    "start_time": 613.44,
    "duration": 4.399
  },
  {
    "text": "सकाळची आरती झाल्यावर बाबांनी सर्व",
    "start_time": 615.12,
    "duration": 5.2
  },
  {
    "text": "भक्तांना दुपारच्या भोजनासाठी घरी जाण्या",
    "start_time": 617.839,
    "duration": 5.201
  },
  {
    "text": "सांगितले अगदी मोजके भक्त त्यांच्या जवळ",
    "start_time": 620.32,
    "duration": 6.4
  },
  {
    "text": "उरले बाबा म्हणाले",
    "start_time": 623.04,
    "duration": 7.039
  },
  {
    "text": "मला बरं वाटत नाही मला बुटीच्या दगडी",
    "start_time": 626.72,
    "duration": 6.96
  },
  {
    "text": "वाड्यात घेऊन चला तिथे मला बरं वाटेल",
    "start_time": 630.079,
    "duration": 7.041
  },
  {
    "text": "बाबांचे अखेरचे शब्द हेच होते मी चाललो",
    "start_time": 633.68,
    "duration": 5.599
  },
  {
    "text": "असा वाड्याकडे घेऊन चला मला वाड्याकडे",
    "start_time": 637.12,
    "duration": 4.399
  },
  {
    "text": "घेऊन चला तिथे सगळे ब्राह्मण माझ्या",
    "start_time": 639.279,
    "duration": 5.601
  },
  {
    "text": "अवतीभवती राहतील असं बोलून बाबा त्यांचा",
    "start_time": 641.519,
    "duration": 6.641
  },
  {
    "text": "कुष्ठरोगी भक्त बागोजी शिंदे याच्या",
    "start_time": 644.88,
    "duration": 5.84
  },
  {
    "text": "खांद्यावर रेले व त्यांनी तेथेच प्राण",
    "start_time": 648.16,
    "duration": 4.4
  },
  {
    "text": "सोडले",
    "start_time": 650.72,
    "duration": 4.64
  },
  {
    "text": "बागोजी जोरात हुणके देऊन रडू लागले व",
    "start_time": 652.56,
    "duration": 6.08
  },
  {
    "text": "म्हणाले बाबा गेले",
    "start_time": 655.36,
    "duration": 6.4
  },
  {
    "text": "नाना निमोणकरांनी बाबांच्या तोंडात थोडं",
    "start_time": 658.64,
    "duration": 6.319
  },
  {
    "text": "पाणी घातलं पण ते बाहेर सांडलं व ते पाहून",
    "start_time": 661.76,
    "duration": 5.44
  },
  {
    "text": "तेही रडू लागले",
    "start_time": 664.959,
    "duration": 4.721
  },
  {
    "text": "त्याच दिवशी पंढरपूरला",
    "start_time": 667.2,
    "duration": 4.879
  },
  {
    "text": "दासगुणू महाराजांच्या स्वप्नात बाबा आले",
    "start_time": 669.68,
    "duration": 6.719
  },
  {
    "text": "आणि म्हणाले मशिद कोसळून पडली आहे",
    "start_time": 672.079,
    "duration": 7.601
  },
  {
    "text": "तेल्यांनी व वाण्यांनी मला खूप त्रास दिला",
    "start_time": 676.399,
    "duration": 6.161
  },
  {
    "text": "म्हणून आता मी ती जागा सोडून निघालो आहे",
    "start_time": 679.68,
    "duration": 5.92
  },
  {
    "text": "मी तुला सांगायला आलो आहे तू ये आणि",
    "start_time": 682.56,
    "duration": 8.08
  },
  {
    "text": "पकोळीच्या फुलांनी मला झाडून टाक",
    "start_time": 685.6,
    "duration": 8.64
  },
  {
    "text": "मग दासगणू महाराज इतर काही भक्तांबरोबर",
    "start_time": 690.64,
    "duration": 6.319
  },
  {
    "text": "तातडीने शिर्डीला आले",
    "start_time": 694.24,
    "duration": 5.76
  },
  {
    "text": "भक्तांनी केलेल्या नोंदीनुसार दुपारी तीन",
    "start_time": 696.959,
    "duration": 7.041
  },
  {
    "text": "वाजता बाबांनी समाधी घेतली",
    "start_time": 700.0,
    "duration": 7.76
  },
  {
    "text": "ते अखेरपर्यंत शुद्धीत होते त्यांनी",
    "start_time": 704.0,
    "duration": 6.8
  },
  {
    "text": "व्यक्त केलेल्या इच्छेचा मान राखून",
    "start_time": 707.76,
    "duration": 6.16
  },
  {
    "text": "त्यांची अंतयात्रा बुटीच्या वाड्यावर",
    "start_time": 710.8,
    "duration": 5.0
  },
  {
    "text": "नेण्यात",
    "start_time": 713.92,
    "duration": 3.23
  },
  {
    "text": "[संगीत]",
    "start_time": 715.8,
    "duration": 2.4
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 717.15,
    "duration": 5.63
  },
  {
    "text": "[संगीत]",
    "start_time": 718.2,
    "duration": 7.4
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 722.78,
    "duration": 9.46
  },
  {
    "text": "सद्गुरू श्री साईनाथ महाराज की जय जय",
    "start_time": 725.6,
    "duration": 8.799
  },
  {
    "text": "समर्थ",
    "start_time": 732.24,
    "duration": 2.159
  },
  {
    "text": "[संगीत]",
    "start_time": 734.79,
    "duration": 10.09
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 739.36,
    "duration": 8.52
  },
  {
    "text": "झाले",
    "start_time": 744.88,
    "duration": 3.0
  },
  {
    "text": "[संगीत]",
    "start_time": 748.58,
    "duration": 2.41
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 749.28,
    "duration": 6.68
  },
  {
    "text": "[संगीत]",
    "start_time": 750.99,
    "duration": 10.59
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 755.96,
    "duration": 5.62
  },
  {
    "text": "[संगीत]",
    "start_time": 761.61,
    "duration": 10.74
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 770.65,
    "duration": 11.03
  },
  {
    "text": "[संगीत]",
    "start_time": 772.35,
    "duration": 10.38
  },
  {
    "text": "आहे",
    "start_time": 781.68,
    "duration": 4.439
  },
  {
    "text": "[संगीत]",
    "start_time": 782.73,
    "duration": 3.389
  },
  {
    "text": "[संगीत]",
    "start_time": 788.52,
    "duration": 7.96
  },
  {
    "text": "[प्रशंसा]",
    "start_time": 794.4,
    "duration": 6.2
  },
  {
    "text": "सर्वांना स्वागत आहे",
    "start_time": 796.48,
    "duration": 4.12
  },
  {
    "text": "आम्हा महा आरतांच्या नाथा चरणी ठेवनिया",
    "start_time": 801.279,
    "duration": 9.441
  },
  {
    "text": "माथा ओवाळू आरती साई शेठच्या नाथा",
    "start_time": 804.959,
    "duration": 9.68
  },
  {
    "text": "आधी व्याधी असती दुःखे",
    "start_time": 810.72,
    "duration": 6.919
  },
  {
    "text": "कर्मफळेची",
    "start_time": 814.639,
