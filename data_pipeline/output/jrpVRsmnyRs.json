[
  {
    "text": "[संगीत]",
    "start_time": 0.28,
    "duration": 17.72
  },
  {
    "text": "आता आपण तीन पद शेवटचे प्रभूंची",
    "start_time": 18.64,
    "duration": 7.84
  },
  {
    "text": "क्रमाने वाटली",
    "start_time": 23.199,
    "duration": 8.361
  },
  {
    "text": "मी माझ कैसा तालिला",
    "start_time": 26.48,
    "duration": 5.08
  },
  {
    "text": "खास की जितका काळ मागे जातो",
    "start_time": 31.76,
    "duration": 5.36
  },
  {
    "text": "तितक",
    "start_time": 35.44,
    "duration": 4.799
  },
  {
    "text": "इतिहासाची अचूकता कमी होण्याची शक्यता",
    "start_time": 37.12,
    "duration": 6.16
  },
  {
    "text": "इतिहासामधले तपशील असतात इतिहास तोच असतो",
    "start_time": 40.239,
    "duration": 4.881
  },
  {
    "text": "पण त्याची अचूकता कदाचित कमी होण्याची",
    "start_time": 43.28,
    "duration": 6.32
  },
  {
    "text": "शक्यता असते आपण जे शिकायचं असतं ते कसं",
    "start_time": 45.12,
    "duration": 6.32
  },
  {
    "text": "शिकाव एवढं प्रत्येक वेळेला आपला",
    "start_time": 49.6,
    "duration": 3.92
  },
  {
    "text": "दृष्टिकोन असला तर ती बरं होईल अस",
    "start_time": 51.44,
    "duration": 5.279
  },
  {
    "text": "आपल्याला म्हणायच तर हे कशाच्या संदर्भात",
    "start_time": 53.52,
    "duration": 5.92
  },
  {
    "text": "आहे तर प्रभूंची आता तीन पद पाहिली",
    "start_time": 56.719,
    "duration": 4.32
  },
  {
    "text": "त्यामध्ये",
    "start_time": 59.44,
    "duration": 7.039
  },
  {
    "text": "शेवटी असं म्हटलं होत आपल्याला की जर",
    "start_time": 61.039,
    "duration": 7.921
  },
  {
    "text": "रामानी कृपा केली",
    "start_time": 66.479,
    "duration": 7.281
  },
  {
    "text": "तर मी पावन होई पावेन विश्राम",
    "start_time": 68.96,
    "duration": 7.76
  },
  {
    "text": "असं होईल असं मला वाटते",
    "start_time": 73.76,
    "duration": 6.08
  },
  {
    "text": "जी एक साधक अवस्था असते त सगळ त्याच्यातल",
    "start_time": 76.72,
    "duration": 5.759
  },
  {
    "text": "प्रतिबिंब आहे अगदी पहिल्या काढ्यापासून",
    "start_time": 79.84,
    "duration": 5.279
  },
  {
    "text": "आपण पाहिला असेल एखाद पद सुद्धा आपल्याला",
    "start_time": 82.479,
    "duration": 6.721
  },
  {
    "text": "खर सांगायचं तर चिंतनाला विचाराला पुरत",
    "start_time": 85.119,
    "duration": 6.481
  },
  {
    "text": "वेळ असतो आपण घेतो पण खरं सांगायचं तर हे",
    "start_time": 89.2,
    "duration": 4.559
  },
  {
    "text": "एक पद सुद्धा पुरेस आहे ती स्थिती कशी",
    "start_time": 91.6,
    "duration": 3.68
  },
  {
    "text": "असते",
    "start_time": 93.759,
    "duration": 4.961
  },
  {
    "text": "त्यानंतर आपण पाहिलं श्री गुरु माझा दत्त",
    "start_time": 95.28,
    "duration": 4.72
  },
  {
    "text": "दया",
    "start_time": 98.72,
    "duration": 6.64
  },
  {
    "text": "अखंडोचर व्याप्त चराचर शाश्वत चित",
